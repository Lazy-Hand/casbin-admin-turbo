// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique @db.VarChar(50)
  password  String     @db.VarChar(500)
  nickname  String     @default("") @db.VarChar(50)
  email     String     @default("") @db.VarChar(100)
  mobile    String     @default("") @db.VarChar(18)
  gender    Int        @default(0) @db.SmallInt
  avatar    String     @default("") @db.VarChar(500)
  status    Int        @default(1) @db.SmallInt
  isAdmin   Boolean    @default(false) @map("is_admin") @db.Boolean
  deptId    Int?       @map("dept_id")
  postId    Int?       @map("post_id")
  roles     UserRole[]
  loginLogs LoginLog[]
  dept      Dept?      @relation("DeptUsers", fields: [deptId], references: [id])
  ledDepts  Dept[]     @relation("DeptLeader")
  post      Post?      @relation(fields: [postId], references: [id])

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  @@index([username])
  @@index([mobile])
  @@index([email])
  @@index([deptId])
  @@index([postId])
  @@map("sys_user")
}

model Role {
  id          Int              @id @default(autoincrement())
  roleName    String           @db.VarChar(50)
  roleCode    String           @unique @db.VarChar(50)
  status      Int              @default(1) @db.SmallInt
  description String           @default("") @db.VarChar(500)
  dataScope   DataScope        @default(DEPT) @map("data_scope")
  customDepts Int[]            @default([]) @map("custom_depts")
  users       UserRole[]
  permissions RolePermission[]

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  @@index([roleCode])
  @@map("sys_role")
}

model Permission {
  id           Int           @id @default(autoincrement())
  permName     String        @default("") @db.VarChar(50)
  permCode     String        @unique @default("") @db.VarChar(50)
  method       String        @default("") @db.VarChar(50)
  component    String        @default("") @db.VarChar(500)
  // 权限类型 'menu'-菜单，'api'-接口，'button'-按钮
  resourceType ResourceType?
  // 菜单权限 'menu'-菜单，'page'-页面，'link'-外链，'iframe'-内链，'window'-新窗口,'divider'-分隔符, 'group'-分组
  // 当resourceType='menu'时有值
  menuType     MenuType?
  path         String        @default("") @db.VarChar(500)

  // 图标(元数据)
  icon     String           @default("") @db.VarChar(500)
  sort     Int              @default(0)
  // 是否缓存 0-否，1-是（元数据）
  cache    Int              @default(0) @db.SmallInt
  // 是否隐藏 0-否，1-是（元数据）
  hidden   Int              @default(0) @db.SmallInt
  // 内链URL，resourceType='menu'且menuType='iframe'时有值
  frameUrl String           @default("") @db.VarChar(500)
  // 状态 0-禁用，1-正常
  status   Int              @default(1) @db.SmallInt
  roles    RolePermission[]
  // 父级ID
  parentId Int?             @default(0)

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  @@index([permCode])
  @@index([resourceType])
  @@index([method, path])
  @@map("sys_permission")
}

enum ResourceType {
  menu
  api
  button
}

enum MenuType {
  menu
  page
  link
  iframe
  window
  divider
  group
}

// 用户-角色关联表
model UserRole {
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("sys_user_role")
}

// 角色-权限关联表
model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("sys_role_permission")
}

// 文件模型
model SysFile {
  id           Int      @id @default(autoincrement())
  filename     String   @unique @db.VarChar(255) // 存储的文件名（唯一）
  originalName String   @db.VarChar(500) // 原始文件名
  size         Int      @db.Integer // 文件大小（字节）
  mimetype     String   @db.VarChar(100) // MIME 类型
  path         String   @db.VarChar(500) // 存储路径
  extension    String   @db.VarChar(20) // 文件扩展名
  fileType     FileType @default(FILE) // 文件类型
  isPublic     Boolean  @default(false) // 是否公开访问
  status       Int      @default(1) @db.SmallInt // 状态：1-正常，0-禁用

  // 业务关联字段
  businessId   Int?    @db.Integer // 关联业务ID
  businessType String? @db.VarChar(100) // 关联业务类型（如：avatar, article, product等）

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  @@index([filename])
  @@index([fileType])
  @@index([status])
  @@index([businessId])
  @@index([businessType])
  @@map("sys_file")
}

enum FileType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  ARCHIVE
  FILE
}

// 定时任务管理
model Timer {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100) // 定时任务名称  
  description String?   @db.VarChar(500) // 描述
  cron        String    @db.VarChar(50) // cron 表达式，支持 6 位(秒 分 时 日 月 周) 或 5 位(分 时 日 月 周)
  taskType    TaskType  @default(HTTP) // 任务类型：HTTP 请求 或 脚本
  target      String    @db.VarChar(1000) // HTTP URL 或 脚本路径
  params      Json? // 额外参数，如 HTTP method、headers、请求体等
  status      Int       @default(1) @db.SmallInt // 1-启用，0-禁用
  lastRunAt   DateTime? @db.Timestamp() // 上次执行时间
  nextRunAt   DateTime? @db.Timestamp() // 下次预计执行时间

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  executionLogs TimerExecutionLog[]

  @@index([status])
  @@index([createdAt])
  @@map("sys_timer")
}

enum TaskType {
  HTTP // HTTP 请求
  SCRIPT // 执行脚本
}

// 定时任务执行日志
model TimerExecutionLog {
  id       Int       @id @default(autoincrement())
  timerId  Int       @db.Integer
  status   Int       @db.SmallInt // 1-成功，0-失败
  startAt  DateTime  @db.Timestamp()
  endAt    DateTime? @db.Timestamp()
  duration Int?      @db.Integer // 执行耗时(毫秒)
  result   String?   @db.Text // 执行结果或错误信息

  timer Timer @relation(fields: [timerId], references: [id], onDelete: Cascade)

  @@index([timerId])
  @@index([startAt])
  @@map("sys_timer_execution_log")
}

// 登录日志
model LoginLog {
  id        Int     @id @default(autoincrement())
  userId    Int?    @db.Integer // 登录成功的用户ID，失败时为 null
  username  String  @db.VarChar(50) // 登录尝试使用的用户名
  ip        String? @db.VarChar(50) // 客户端IP
  userAgent String? @db.VarChar(500) // 浏览器/设备信息
  status    Int     @default(1) @db.SmallInt // 1-成功，0-失败
  message   String? @db.VarChar(200) // 失败时的提示信息

  createdAt DateTime @default(now()) @db.Timestamp()

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([username])
  @@index([createdAt])
  @@map("sys_login_log")
}

// 字典类型
model DictType {
  id          Int        @id @default(autoincrement())
  dictName    String     @db.VarChar(100) // 字典名称
  dictCode    String     @unique @db.VarChar(100) // 字典编码（唯一）
  description String     @default("") @db.VarChar(500) // 描述
  status      Int        @default(1) @db.SmallInt // 1-启用，0-停用
  items       DictItem[]

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  @@index([dictCode])
  @@index([status])
  @@map("sys_dict_type")
}

// 字典项
model DictItem {
  id         Int    @id @default(autoincrement())
  dictTypeId Int    @db.Integer // 所属字典类型ID
  label      String @db.VarChar(100) // 显示标签
  value      String @db.VarChar(100) // 字典值
  colorType  String @default("") @db.VarChar(50) // 颜色标识（success/warning/danger/info）
  sort       Int    @default(0) // 排序
  status     Int    @default(1) @db.SmallInt // 1-启用，0-停用

  dictType DictType @relation(fields: [dictTypeId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  @@index([dictTypeId])
  @@index([sort])
  @@index([status])
  @@map("sys_dict_item")
}

// 操作日志
model OperationLog {
  id          Int          @id @default(autoincrement())
  userId      Int?         @db.Integer // 操作人ID
  username    String       @db.VarChar(50) // 操作人用户名
  module      String       @db.VarChar(50) // 模块名
  operation   LogOperation @default(CREATE) // 操作类型
  description String?      @db.VarChar(500) // 操作描述
  method      String       @db.VarChar(10) // HTTP方法
  path        String       @db.VarChar(200) // API路径
  params      Json? // 请求参数（精简后）
  ip          String?      @db.VarChar(50) // 客户端IP
  userAgent   String?      @db.VarChar(500) // 浏览器/设备信息
  status      Int          @default(1) @db.SmallInt // 1-成功，0-失败
  result      String?      @db.Text // 结果或错误信息
  duration    Int?         @db.Integer // 执行耗时(毫秒)
  createdAt   DateTime     @default(now()) @db.Timestamp()

  @@index([userId])
  @@index([module])
  @@index([operation])
  @@index([createdAt])
  @@map("sys_operation_log")
}

enum LogOperation {
  CREATE
  UPDATE
  DELETE
}

// 数据范围枚举
enum DataScope {
  ALL
  CUSTOM
  DEPT
  DEPT_AND_CHILD
}

// 部门模型
model Dept {
  id        Int     @id @default(autoincrement())
  name      String  @db.VarChar(50)
  parentId  Int?    @map("parent_id")
  ancestors String? @map("ancestors") // "0,1,5"
  leaderId  Int?    @map("leader_id")
  status    Int     @default(1) @db.SmallInt
  sort      Int     @default(0)
  remark    String? @db.VarChar(500)

  users    User[] @relation("DeptUsers")
  children Dept[] @relation("DeptToDept")
  parent   Dept?  @relation("DeptToDept", fields: [parentId], references: [id])
  leader   User?  @relation("DeptLeader", fields: [leaderId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime?
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  @@index([parentId])
  @@index([ancestors])
  @@index([status])
  @@map("sys_dept")
}

// 岗位模型
model Post {
  id       Int     @id @default(autoincrement())
  postName String  @db.VarChar(50)
  postCode String  @unique @db.VarChar(50)
  sort     Int     @default(0)
  status   Int     @default(1) @db.SmallInt
  remark   String? @db.VarChar(500)
  users    User[]

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  @@index([postCode])
  @@index([status])
  @@map("sys_post")
}

// 系统配置
model SysConfig {
  id          Int    @id @default(autoincrement())
  configKey   String @unique @db.VarChar(100) // 配置键
  configValue String @db.VarChar(500) // 配置值
  description String @default("") @db.VarChar(500) // 描述
  status      Int    @default(1) @db.SmallInt // 1-启用, 0-禁用

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  @@index([configKey])
  @@index([status])
  @@map("sys_config")
}
