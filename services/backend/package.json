{
  "name": "@casbin-admin/backend",
  "version": "0.0.1",
  "description": "Casbin Admin NestJS Server",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "node scripts/migrate.ts up",
    "db:migrate:status": "node scripts/migrate.ts status",
    "db:seed": "node db/seed.ts",
    "drizzle:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "build": "nest build",
    "format": "oxfmt --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" \"db/**/*.ts\" \"*.ts\" \"!dist/**\" \"!node_modules/**\"",
    "format:check": "oxfmt --check --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" \"db/**/*.ts\" \"*.ts\" \"!dist/**\" \"!node_modules/**\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "run-s lint:oxlint lint:eslint",
    "lint:fix": "run-s lint:oxlint:fix lint:eslint:fix",
    "lint:oxlint": "oxlint .",
    "lint:oxlint:fix": "oxlint . --fix",
    "lint:eslint": "eslint . --cache",
    "lint:eslint:fix": "eslint . --fix --cache",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:performance": "tsx scripts/performance-test.ts",
    "db:check-indexes": "psql $DATABASE_URL -f scripts/check-indexes.sql",
    "db:maintenance": "psql $DATABASE_URL -f scripts/db-maintenance.sql",
    "db:analyze": "psql $DATABASE_URL -c 'ANALYZE;'",
    "db:vacuum": "psql $DATABASE_URL -c 'VACUUM ANALYZE;'",
    "db:enable-slow-log": "psql $DATABASE_URL -f scripts/enable-slow-query-log.sql",
    "db:reset-sequences": "tsx scripts/reset-sequences.ts",
    "type-check": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.5",
    "@scalar/nestjs-api-reference": "^1.0.23",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cron": "^4.4.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.9.2",
    "js-yaml": "^4.1.1",
    "nest-casl": "^1.9.15",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "request-ip": "^3.3.0",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@casbin-admin/eslint-config": "workspace:*",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "catalog:",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "catalog:",
    "@types/passport-jwt": "^4.0.1",
    "@types/request-ip": "^0.0.41",
    "@types/supertest": "^6.0.2",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "fast-check": "^4.5.3",
    "globals": "catalog:",
    "jest": "^30.0.0",
    "jiti": "catalog:",
    "npm-run-all2": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "prettier": "3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
