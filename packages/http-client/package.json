{
  "name": "@casbin-admin/http-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./business": {
      "types": "./dist/business.d.ts",
      "import": "./dist/business.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./check-status": {
      "types": "./dist/check-status.d.ts",
      "import": "./dist/check-status.js"
    },
    "./request": {
      "types": "./dist/request.d.ts",
      "import": "./dist/request.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "postinstall": "pnpm exec tsc -p tsconfig.json",
    "test": "pnpm exec tsc -p tsconfig.json && node --test dist/*.test.js",
    "type-check": "pnpm exec tsc --noEmit -p tsconfig.json",
    "smoke-check": "node dist/smoke-check.js"
  },
  "dependencies": {
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
